# Microsoft Graph MCP - Environment Configuration
# Copy this file to .env and fill in your values.

# Azure AD Application credentials (required)
TENANT_ID=your-azure-ad-tenant-id
CLIENT_ID=your-app-registration-client-id

# Required for client_credentials (app-only) flow (default)
CLIENT_SECRET=your-client-secret

# Authentication flow: 'client_credentials' (default) or 'device_code'
AUTH_FLOW=client_credentials
