{
  "AzureAd": {
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "Scopes": [
      "User.Read",
      "Mail.Read",
      "Mail.Send",
      "Calendars.ReadWrite",
      "ChannelMessage.Read.All",
      "Team.ReadBasic.All",
      "Files.ReadWrite.All",
      "Notes.ReadWrite.All",
      "Tasks.ReadWrite",
      "offline_access"
    ]
  },
  "TokenCache": {
    "StorageConnectionString": "YOUR_AZURE_STORAGE_CONNECTION_STRING",
    "ContainerName": "msal-token-cache",
    "BlobNamePrefix": "mcp-user-"
  },
  "Session": {
    "TimeoutHours": 8,
    "MaxConcurrentSessions": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Graph": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:8080"
}
